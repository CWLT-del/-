<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.account.pojo.MaintainMapper">
    <insert id="insertMaintain" parameterType="com.account.pojo.Maintain">
        INSERT INTO t_maintain (id, content, dormitory, status, updateUser)
        VALUES (#{id}, #{content}, #{dormitory}, #{status}, #{updateUser})
    </insert>
    <update id="updateMaintain" parameterType="com.account.pojo.Maintain">
        UPDATE t_maintain SET status = '已处理' WHERE id = #{id}
    </update>
    <update id="updateMaintainUnDone" parameterType="int">
        UPDATE t_maintain SET status = '未处理' WHERE id = #{id}
    </update>
    <delete id="deleteMaintain" parameterType="int">
        DELETE FROM t_maintain WHERE id = #{id}
    </delete>
    <select id="selectAll" resultType="com.account.pojo.Maintain">
        select * from t_maintain;
    </select>
    <select id="selectcompet" resultType="int">
        select competence from t_maintain where id = #{id};
    </select>
    <select id="selectById" parameterType="int" resultType="com.account.pojo.Maintain">
        SELECT * FROM t_maintain WHERE id = #{id};
    </select>
    <select id="selectAllMaintain" parameterType="String" resultType="com.account.pojo.Maintain">
        SELECT * FROM t_maintain WHERE updateUser = #{updateUser};
    </select>
    <select id="selectAllMaintainstatus" resultType="com.account.pojo.Maintain">
        SELECT * FROM t_maintain;
    </select>
</mapper>